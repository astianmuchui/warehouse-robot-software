<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SGG — Gyro Replay</title>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/assets/css/style.css">
     
    <script src="/assets/js/tailwind.js"></script>
        <script>tailwind.config = { theme: { extend: { fontFamily: { sans: ['Outfit', 'sans-serif'] } } } }</script>
        <script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>
    </head>

    <body class="min-h-screen font-sans bg-[#041022] text-slate-100">

        <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
            <div
                class="absolute -top-24 -left-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(59,130,246,0.15)_0%,transparent_70%)] blur-xl">
            </div>
            <div
                class="absolute -bottom-28 -right-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(6,182,212,0.12)_0%,transparent_70%)] blur-xl">
            </div>
        </div>


        <aside
            class="fixed top-0 left-0 h-screen w-56 z-20 flex flex-col border-r border-white/10 bg-slate-950/70 backdrop-blur-xl">
            <div class="px-6 py-5 border-b border-white/10">
                <span class="text-lg font-extrabold text-white tracking-tight">SGG</span>
                <span class="ml-1 text-sky-400 text-sm font-semibold">Robot</span>
            </div>
            <nav class="flex-1 px-3 py-4 space-y-1">
                <a href="/dashboard" class="nav-link">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                    </svg>Dashboard</a>
                <a href="/analysis" class="nav-link">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>Analysis</a>
                <a href="/events" class="nav-link">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>Events</a>
                <a href="/thresholds" class="nav-link">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                    </svg>Thresholds</a>
                <a href="/replay" class="nav-link active">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>Replay</a>
            </nav>
            <div class="px-4 py-3 border-t border-white/10">
                <p class="text-xs text-slate-500">Device: <span class="text-sky-400 font-mono">{{.DeviceID}}</span></p>
            </div>
        </aside>

        <main class="relative z-10 ml-56 min-h-screen">
            <header
                class="sticky top-0 z-10 flex items-center justify-between px-8 py-4 border-b border-white/10 bg-slate-950/60 backdrop-blur-md">
                <h1 class="text-xl font-bold text-white">Gyro Replay</h1>
                <span class="text-xs text-slate-400">Replay recorded IMU orientation data</span>
            </header>

            <div class="px-8 py-6 space-y-6">


                <div class="panel flex flex-wrap items-end gap-4">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs text-slate-400 font-medium">Readings to load</label>
                        <div class="flex items-center gap-3">
                            <input type="range" id="limit-slider" min="10" max="200" step="10" value="50"
                                class="w-40 accent-sky-400">
                            <span class="text-sm font-mono text-sky-300 w-8 text-right" id="limit-display">50</span>
                        </div>
                    </div>
                    <button id="load-btn"
                        class="px-5 py-2 rounded-lg bg-sky-600 hover:bg-sky-500 text-white text-sm font-semibold transition-colors">
                        Load Frames
                    </button>
                    <span class="text-xs text-slate-500" id="load-status">No data loaded</span>
                </div>


                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="panel">
                        <h2 class="panel-title">3D Orientation</h2>
                        <canvas id="replay-canvas" class="h-[300px] w-full rounded-xl bg-slate-950/60"></canvas>
                        <div class="mt-3 grid grid-cols-3 gap-2 text-center text-xs text-slate-400">
                            <div>Accel X<br><span class="font-mono text-sky-300" id="r-ax">—</span></div>
                            <div>Accel Y<br><span class="font-mono text-sky-300" id="r-ay">—</span></div>
                            <div>Accel Z<br><span class="font-mono text-sky-300" id="r-az">—</span></div>
                            <div>Gyro X<br><span class="font-mono text-emerald-300" id="r-gx">—</span></div>
                            <div>Gyro Y<br><span class="font-mono text-emerald-300" id="r-gy">—</span></div>
                            <div>Gyro Z<br><span class="font-mono text-emerald-300" id="r-gz">—</span></div>
                        </div>
                    </div>


                    <div class="panel flex flex-col gap-4">
                        <h2 class="panel-title">Playback Controls</h2>


                        <div class="flex flex-col gap-1">
                            <div class="flex justify-between text-xs text-slate-500">
                                <span>Frame</span>
                                <span id="frame-counter">0 / 0</span>
                            </div>
                            <input type="range" id="scrubber" min="0" max="0" value="0" class="w-full accent-sky-400"
                                disabled>
                        </div>


                        <p class="text-xs text-slate-500">Recorded at: <span class="font-mono text-slate-300"
                                id="frame-time">—</span></p>


                        <div class="flex items-center gap-3 flex-wrap">
                            <button id="play-btn" disabled
                                class="flex items-center gap-2 px-5 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500 disabled:opacity-40 disabled:cursor-not-allowed text-white text-sm font-semibold transition-colors">
                                <svg id="play-icon" class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path
                                        d="M6.3 2.84A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.27l9.34-5.89a1.5 1.5 0 000-2.54L6.3 2.84z" />
                                </svg>
                                <span id="play-label">Play</span>
                            </button>

                            <button id="restart-btn" disabled
                                class="flex items-center gap-2 px-4 py-2 rounded-lg border border-white/10 bg-slate-800 hover:bg-slate-700 disabled:opacity-40 disabled:cursor-not-allowed text-slate-200 text-sm transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                </svg>
                                Restart
                            </button>

                            <div class="flex items-center gap-2 ml-auto">
                                <label class="text-xs text-slate-400">Speed</label>
                                <select id="speed-select"
                                    class="bg-slate-800 border border-white/10 text-sm text-slate-200 rounded-lg px-2 py-1 focus:outline-none">
                                    <option value="0.5">0.5×</option>
                                    <option value="1" selected>1×</option>
                                    <option value="2">2×</option>
                                    <option value="4">4×</option>
                                </select>
                            </div>
                        </div>


                        <div class="mt-2">
                            <div class="h-1.5 rounded-full bg-slate-800 overflow-hidden">
                                <div id="progress-bar"
                                    class="h-full rounded-full bg-sky-500 transition-all duration-100" style="width:0%">
                                </div>
                            </div>
                        </div>


                        <div class="mt-auto pt-4 border-t border-white/05 text-xs text-slate-500 space-y-1">
                            <p>Frames are replayed oldest → newest.</p>
                            <p>Orientation derived from accelerometer gravity vector.</p>
                        </div>
                    </div>
                </div>

            </div>
        </main>

        <script src="/assets/js/replay.js"></script>
        <script>window.SGG_DEVICE_ID = "{{.DeviceID}}";</script>
    </body>

</html>