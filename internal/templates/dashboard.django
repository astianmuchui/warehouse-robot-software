<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SGG — Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/assets/js/tailwind.js"></script>
    <script>tailwind.config={theme:{extend:{fontFamily:{sans:['Outfit','sans-serif']}}}}</script>
    
    <script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>
</head>
<body class="min-h-screen font-sans bg-[#041022] text-slate-100">

<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-24 -left-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(59,130,246,0.15)_0%,transparent_70%)] blur-xl animate-[float_18s_ease-in-out_infinite]"></div>
    <div class="absolute -bottom-28 -right-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(6,182,212,0.12)_0%,transparent_70%)] blur-xl"></div>
</div>


<aside class="fixed top-0 left-0 h-screen w-56 z-20 flex flex-col border-r border-white/10 bg-slate-950/70 backdrop-blur-xl">
    <div class="px-6 py-5 border-b border-white/10">
        <span class="text-lg font-extrabold text-white tracking-tight">SGG</span>
        <span class="ml-1 text-sky-400 text-sm font-semibold">Robot</span>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-1">
        <a href="/dashboard" class="nav-link active">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>Dashboard</a>
        <a href="/analysis" class="nav-link">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>Analysis</a>
        <a href="/events" class="nav-link">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>Events</a>
        <a href="/thresholds" class="nav-link">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>Thresholds</a>
        <a href="/replay" class="nav-link">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Replay</a>
    </nav>
    <div class="px-4 py-3 border-t border-white/10">
        <p class="text-xs text-slate-500">Device: <span class="text-sky-400 font-mono">{{.DeviceID}}</span></p>
    </div>
</aside>

<main class="relative z-10 ml-56 min-h-screen">
    <header class="sticky top-0 z-10 flex items-center justify-between px-8 py-4 border-b border-white/10 bg-slate-950/60 backdrop-blur-md">
        <h1 class="text-xl font-bold text-white">Dashboard</h1>
        <span class="flex items-center gap-2 text-xs text-slate-400">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>Live • refreshes every 5 s
        </span>
    </header>

    <div class="px-8 py-6 space-y-6">

        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="kpi-row">
            <div class="kpi-card" id="kpi-temp">
                <p class="kpi-label">Temperature</p>
                <p class="kpi-value" id="val-temp">
                    {{if .LatestTelemetry}}{{printf "%.1f" .LatestTelemetry.TempC}}°C{{else}}—{{end}}
                </p>
            </div>
            <div class="kpi-card" id="kpi-hum">
                <p class="kpi-label">Humidity</p>
                <p class="kpi-value" id="val-hum">
                    {{if .LatestTelemetry}}{{printf "%.1f" .LatestTelemetry.HumidityPct}}%{{else}}—{{end}}
                </p>
            </div>
            <div class="kpi-card" id="kpi-aq">
                <p class="kpi-label">Air Quality</p>
                <p class="kpi-value" id="val-aq">
                    {{if .LatestTelemetry}}{{printf "%.0f" .LatestTelemetry.AirQualityPPM}} ppm{{else}}—{{end}}
                </p>
            </div>
            <div class="kpi-card" id="kpi-dist">
                <p class="kpi-label">Distance</p>
                <p class="kpi-value" id="val-dist">
                    {{if .LatestTelemetry}}{{printf "%.1f" .LatestTelemetry.DistanceCm}} cm{{else}}—{{end}}
                </p>
            </div>
        </div>

        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="panel">
                <h2 class="panel-title">3D Orientation (Live IMU)</h2>
                <canvas id="gyro-canvas" class="h-[280px] w-full rounded-xl bg-slate-950/60"></canvas>
                <div class="mt-3 grid grid-cols-3 gap-2 text-center text-xs text-slate-400">
                    <div>Accel X<br><span class="font-mono text-sky-300" id="imu-ax">—</span></div>
                    <div>Accel Y<br><span class="font-mono text-sky-300" id="imu-ay">—</span></div>
                    <div>Accel Z<br><span class="font-mono text-sky-300" id="imu-az">—</span></div>
                    <div>Gyro X<br><span class="font-mono text-emerald-300" id="imu-gx">—</span></div>
                    <div>Gyro Y<br><span class="font-mono text-emerald-300" id="imu-gy">—</span></div>
                    <div>Gyro Z<br><span class="font-mono text-emerald-300" id="imu-gz">—</span></div>
                </div>
            </div>

            
            <div class="panel">
                <h2 class="panel-title">Recent Events</h2>
                <div class="space-y-2 overflow-y-auto max-h-72" id="event-list">
                    {{range .RecentEvents}}
                    <div class="event-row severity-{{.Severity}}">
                        <span class="event-badge">{{.EventType}}</span>
                        <span class="text-xs text-slate-300 truncate flex-1">{{.Message}}</span>
                        <span class="text-xs text-slate-500 ml-2 shrink-0">{{.CreatedAt.Format "15:04:05"}}</span>
                    </div>
                    {{else}}
                    <p class="text-slate-500 text-sm py-4 text-center">No events yet</p>
                    {{end}}
                </div>
            </div>
        </div>

        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="panel">
                <h2 class="panel-title">Temperature &amp; Humidity (last 1 h)</h2>
                <div class="relative h-[200px]">
                    <canvas id="env-chart"></canvas>
                </div>
            </div>
            <div class="panel">
                <h2 class="panel-title">Air Quality (last 1 h)</h2>
                <div class="relative h-[200px]">
                    <canvas id="aq-chart"></canvas>
                </div>
            </div>
        </div>

    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/assets/js/dashboard.js"></script>
<script>
    window.SGG_DEVICE_ID = "{{.DeviceID}}";
</script>
</body>
</html>
