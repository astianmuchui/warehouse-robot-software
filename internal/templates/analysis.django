<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SGG  Analysis</title>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/assets/css/style.css">

        <script src="/assets/js/tailwind.js"></script>
        <script>tailwind.config = { theme: { extend: { fontFamily: { sans: ['Outfit', 'sans-serif'] } } } }</script>
        <script src="https://code.highcharts.com/highcharts.js"></script>
        <script src="https://code.highcharts.com/modules/exporting.js"></script>
        <script src="https://code.highcharts.com/modules/offline-exporting.js"></script>
        <script src="https://code.highcharts.com/modules/accessibility.js"></script>
    </head>

    <body class="min-h-screen font-sans bg-[#041022] text-slate-100">

        <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
            <div class="absolute -top-24 -left-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(59,130,246,0.15)_0%,transparent_70%)] blur-xl"></div>
            <div class="absolute -bottom-28 -right-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(6,182,212,0.12)_0%,transparent_70%)] blur-xl"></div>
        </div>

        {{template "sidebar" .}}

        <main class="relative z-10 sgg-content min-h-screen">
            <header class="sticky top-0 z-10 flex items-center justify-between pl-16 pr-4 sm:px-6 lg:px-8 py-4 gap-3 border-b border-white/10 bg-slate-950/60 backdrop-blur-md">
                <h1 class="text-xl font-bold text-white">Analysis</h1>
                <div class="flex flex-wrap items-center gap-2">
                    <select id="hours-select" class="bg-slate-800 border border-white/10 text-sm text-slate-200 rounded-lg px-3 py-1.5 focus:outline-none">
                        <option value="1">Last 1 hour</option>
                        <option value="6">Last 6 hours</option>
                        <option value="24" selected>Last 24 hours</option>
                        <option value="72">Last 3 days</option>
                        <option value="168">Last 7 days</option>
                    </select>
                    <div class="hidden sm:block w-px h-6 bg-white/10"></div>
                    <label class="flex items-center gap-1.5 text-xs text-slate-400">
                        From
                        <input id="range-start" type="datetime-local"
                               class="bg-slate-800 border border-white/10 text-sm text-slate-200 rounded-lg px-2 py-1 focus:outline-none focus:border-sky-500/50">
                    </label>
                    <label class="flex items-center gap-1.5 text-xs text-slate-400">
                        To
                        <input id="range-end" type="datetime-local"
                               class="bg-slate-800 border border-white/10 text-sm text-slate-200 rounded-lg px-2 py-1 focus:outline-none focus:border-sky-500/50">
                    </label>
                    <button id="range-clear" class="text-xs text-slate-400 hover:text-slate-200 px-2 py-1.5 rounded-lg border border-transparent hover:border-white/10 transition-colors" title="Clear date range">Clear</button>
                    <button id="refresh-btn" class="text-xs bg-sky-600 hover:bg-sky-500 text-white px-3 py-1.5 rounded-lg transition-colors">Refresh</button>
                </div>
            </header>

            <div class="px-4 sm:px-6 lg:px-8 py-6 space-y-6">

                <!-- Stats row (7 cards) -->
                <div class="grid grid-cols-2 md:grid-cols-7 gap-4" id="stats-row">
                    <div class="stat-card">
                        <p class="stat-label">Avg Temp</p>
                        <p class="stat-val" id="stat-temp-avg">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Max Temp</p>
                        <p class="stat-val text-orange-400" id="stat-temp-max">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Avg Humidity</p>
                        <p class="stat-val" id="stat-hum-avg">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Avg Air Quality</p>
                        <p class="stat-val" id="stat-aq-avg">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Peak PPM</p>
                        <p class="stat-val text-amber-400" id="stat-aq-peak">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">AQ Status</p>
                        <p class="stat-val text-sm" id="stat-aq-class">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Total Readings</p>
                        <p class="stat-val text-sky-400" id="stat-total-readings">—</p>
                    </div>
                </div>

                <!-- Temp / Humidity -->
                <div class="panel">
                    <h2 class="panel-title">Temperature &amp; Humidity over time</h2>
                    <div class="relative h-[480px]">
                        <div id="chart-env" class="absolute inset-0"></div>
                        <div class="chart-loader" id="loader-env"><div class="chart-spinner"></div></div>
                    </div>
                    <p class="hc-zoom-tip">Drag to zoom · Shift-drag to pan · Double-click to reset · ⋮ to export / fullscreen</p>
                </div>

                <!-- MQ-135 Air Quality Analysis (deep-dive) -->
                <div class="panel space-y-5">
                    <h2 class="panel-title">MQ-135 Air Quality Analysis</h2>

                    <!-- Gauge + current status -->
                    <div class="flex items-start gap-6">
                        <!-- Gauge -->
                        <div class="flex-1 space-y-2">
                            <div class="relative">
                                <!-- Colored band bar -->
                                <div class="flex h-5 rounded-full overflow-hidden border border-white/10">
                                    <!-- widths proportional to range within 0-1200 scale -->
                                    <div title="Excellent (0-100)"  style="width:8.33%;background:#22c55e"></div>
                                    <div title="Good (101-200)"     style="width:8.33%;background:#84cc16"></div>
                                    <div title="Moderate (201-400)" style="width:16.67%;background:#eab308"></div>
                                    <div title="Poor (401-600)"     style="width:16.67%;background:#f97316"></div>
                                    <div title="Very Poor (601-1000)" style="width:33.33%;background:#ef4444"></div>
                                    <div title="Hazardous (1000+)"  style="width:16.67%;background:#dc2626"></div>
                                </div>
                                <!-- Marker -->
                                <div id="aq-gauge-marker" class="absolute top-0 w-0.5 h-5 bg-white shadow-lg rounded pointer-events-none" style="left:0%;transform:translateX(-50%)"></div>
                            </div>
                            <!-- Scale labels -->
                            <div class="flex justify-between text-[10px] text-slate-600 font-mono px-0.5">
                                <span>0</span><span>100</span><span>200</span><span>400</span><span>600</span><span>1000</span><span>1200+</span>
                            </div>
                        </div>
                        <!-- Current status box -->
                        <div class="shrink-0 text-right">
                            <p id="aq-gauge-val" class="text-2xl font-bold text-white">—</p>
                            <p id="aq-gauge-label" class="text-sm font-semibold mt-0.5">—</p>
                            <p id="aq-gauge-desc" class="text-xs text-slate-500 mt-1 max-w-[200px]">—</p>
                        </div>
                    </div>

                    <!-- PPM over time chart -->
                    <div class="relative h-[560px]">
                        <div id="chart-aq" class="absolute inset-0"></div>
                        <div class="chart-loader" id="loader-aq"><div class="chart-spinner"></div></div>
                    </div>
                    <p class="hc-zoom-tip">Drag to zoom · Shift-drag to pan · Double-click to reset · ⋮ to export / fullscreen</p>

                    <!-- Zone time distribution -->
                    <div>
                        <p class="text-xs font-semibold text-slate-500 mb-3 uppercase tracking-wider">Time in Zone</p>
                        <div id="aq-zones" class="space-y-2"></div>
                    </div>
                </div>

                <!-- MQ-135 Gas Reference -->
                <div class="panel">
                    <h2 class="panel-title">MQ-135 Gas Detection Reference</h2>
                    <p class="text-xs text-slate-500 mb-4">The MQ-135 outputs a single combined PPM value calibrated to NH₃ (ammonia). It cannot distinguish individual gases — the reading reflects the aggregate response to all pollutants present. Values below show the approximate sensor output when each gas reaches its safety threshold.</p>
                    <div class="overflow-x-auto">
                        <table class="w-full text-xs">
                            <thead>
                                <tr class="text-left border-b border-white/10">
                                    <th class="pb-2 pr-4 text-slate-400 font-semibold">Gas</th>
                                    <th class="pb-2 pr-4 text-slate-400 font-semibold">Formula</th>
                                    <th class="pb-2 pr-4 text-slate-400 font-semibold">Detection Range</th>
                                    <th class="pb-2 pr-4 text-slate-400 font-semibold">Safety Limit</th>
                                    <th class="pb-2 pr-4 text-slate-400 font-semibold">Standard</th>
                                    <th class="pb-2 text-slate-400 font-semibold">Sensor ≈ at limit</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/5">
                                <tr>
                                    <td class="py-2 pr-4 font-medium text-emerald-300">Ammonia</td>
                                    <td class="py-2 pr-4 font-mono text-slate-300">NH₃</td>
                                    <td class="py-2 pr-4 text-slate-400">10 – 300 ppm</td>
                                    <td class="py-2 pr-4 text-yellow-400 font-medium">25 ppm</td>
                                    <td class="py-2 pr-4 text-slate-500">ACGIH TLV-TWA</td>
                                    <td class="py-2 font-mono text-amber-400">~300 ppm</td>
                                </tr>
                                <tr>
                                    <td class="py-2 pr-4 font-medium text-sky-300">Carbon Dioxide</td>
                                    <td class="py-2 pr-4 font-mono text-slate-300">CO₂</td>
                                    <td class="py-2 pr-4 text-slate-400">350 – 10,000 ppm</td>
                                    <td class="py-2 pr-4 text-yellow-400 font-medium">5,000 ppm</td>
                                    <td class="py-2 pr-4 text-slate-500">OSHA PEL (8h TWA)</td>
                                    <td class="py-2 font-mono text-amber-400">~800 ppm</td>
                                </tr>
                                <tr>
                                    <td class="py-2 pr-4 font-medium text-orange-300">Carbon Monoxide</td>
                                    <td class="py-2 pr-4 font-mono text-slate-300">CO</td>
                                    <td class="py-2 pr-4 text-slate-400">10 – 1,000 ppm</td>
                                    <td class="py-2 pr-4 text-red-400 font-medium">25 ppm</td>
                                    <td class="py-2 pr-4 text-slate-500">WHO guideline</td>
                                    <td class="py-2 font-mono text-red-400">~200 ppm</td>
                                </tr>
                                <tr>
                                    <td class="py-2 pr-4 font-medium text-purple-300">Benzene</td>
                                    <td class="py-2 pr-4 font-mono text-slate-300">C₆H₆</td>
                                    <td class="py-2 pr-4 text-slate-400">10 – 1,000 ppm</td>
                                    <td class="py-2 pr-4 text-red-400 font-medium">1 ppm</td>
                                    <td class="py-2 pr-4 text-slate-500">OSHA PEL (carcinogen)</td>
                                    <td class="py-2 font-mono text-red-400">~100 ppm</td>
                                </tr>
                                <tr>
                                    <td class="py-2 pr-4 font-medium text-lime-300">Alcohol / VOCs</td>
                                    <td class="py-2 pr-4 font-mono text-slate-300">C₂H₅OH</td>
                                    <td class="py-2 pr-4 text-slate-400">100 – 2,000 ppm</td>
                                    <td class="py-2 pr-4 text-yellow-400 font-medium">1,000 ppm</td>
                                    <td class="py-2 pr-4 text-slate-500">ACGIH TLV-TWA</td>
                                    <td class="py-2 font-mono text-amber-400">~700 ppm</td>
                                </tr>
                                <tr>
                                    <td class="py-2 pr-4 font-medium text-slate-300">Smoke</td>
                                    <td class="py-2 pr-4 font-mono text-slate-300">—</td>
                                    <td class="py-2 pr-4 text-slate-400">200 – 10,000 ppm</td>
                                    <td class="py-2 pr-4 text-slate-400 font-medium">Visible &gt; 400 ppm</td>
                                    <td class="py-2 pr-4 text-slate-500">Visual threshold</td>
                                    <td class="py-2 font-mono text-amber-400">~400 ppm</td>
                                </tr>
                                <tr>
                                    <td class="py-2 pr-4 font-medium text-cyan-300">Nitrogen Oxides</td>
                                    <td class="py-2 pr-4 font-mono text-slate-300">NOₓ</td>
                                    <td class="py-2 pr-4 text-slate-400">10 – 300 ppm</td>
                                    <td class="py-2 pr-4 text-red-400 font-medium">3 ppm</td>
                                    <td class="py-2 pr-4 text-slate-500">WHO annual guideline</td>
                                    <td class="py-2 font-mono text-red-400">~80 ppm</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-[10px] text-slate-600 mt-3">* "Sensor ≈ at limit" values are approximated from MQ-135 Rs/Ro sensitivity curves. Calibrate sensor in known-clean air (Ro baseline) for accurate readings. 24h warm-up recommended for stable output.</p>
                </div>

                <!-- Accelerometer -->
                <div class="panel">
                    <h2 class="panel-title">Accelerometer (m/s²) over time</h2>
                    <div class="relative h-[480px]">
                        <div id="chart-accel" class="absolute inset-0"></div>
                        <div class="chart-loader" id="loader-accel"><div class="chart-spinner"></div></div>
                    </div>
                    <p class="hc-zoom-tip">Drag to zoom · Shift-drag to pan · Double-click to reset · ⋮ to export / fullscreen</p>
                </div>

                <!-- Gyroscope -->
                <div class="panel">
                    <h2 class="panel-title">Gyroscope (rad/s) over time</h2>
                    <div class="relative h-[480px]">
                        <div id="chart-gyro" class="absolute inset-0"></div>
                        <div class="chart-loader" id="loader-gyro"><div class="chart-spinner"></div></div>
                    </div>
                    <p class="hc-zoom-tip">Drag to zoom · Shift-drag to pan · Double-click to reset · ⋮ to export / fullscreen</p>
                </div>

                <!-- Proximity -->
                <div class="panel">
                    <h2 class="panel-title">Proximity Distance (cm) over time</h2>
                    <div class="relative h-[480px]">
                        <div id="chart-dist" class="absolute inset-0"></div>
                        <div class="chart-loader" id="loader-dist"><div class="chart-spinner"></div></div>
                    </div>
                    <p class="hc-zoom-tip">Drag to zoom · Shift-drag to pan · Double-click to reset · ⋮ to export / fullscreen</p>
                </div>

            </div>
        </main>

        <script src="/assets/js/analysis.js"></script>
        <script>window.SGG_DEVICE_ID = "{{.DeviceID}}";</script>
    </body>

</html>
