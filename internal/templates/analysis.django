<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>SGG — Analysis</title>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="/assets/css/style.css">
        <script src="https://cdn.tailwindcss.com"></script>
        <script>tailwind.config = { theme: { extend: { fontFamily: { sans: ['Outfit', 'sans-serif'] } } } }</script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script
            src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    </head>

    <body class="min-h-screen font-sans bg-[#041022] text-slate-100">

        <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
            <div
                class="absolute -top-24 -left-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(59,130,246,0.15)_0%,transparent_70%)] blur-xl">
            </div>
            <div
                class="absolute -bottom-28 -right-24 h-[55vw] w-[55vw] rounded-full bg-[radial-gradient(circle,rgba(6,182,212,0.12)_0%,transparent_70%)] blur-xl">
            </div>
        </div>

        <aside
            class="fixed top-0 left-0 h-screen w-56 z-20 flex flex-col border-r border-white/10 bg-slate-950/70 backdrop-blur-xl">
            <div class="px-6 py-5 border-b border-white/10">
                <span class="text-lg font-extrabold text-white tracking-tight">SGG</span>
                <span class="ml-1 text-sky-400 text-sm font-semibold">Robot</span>
            </div>
            <nav class="flex-1 px-3 py-4 space-y-1">
                <a href="/dashboard" class="nav-link">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                    </svg>Dashboard</a>
                <a href="/analysis" class="nav-link active">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>Analysis</a>
                <a href="/events" class="nav-link">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>Events</a>
                <a href="/thresholds" class="nav-link">
                    <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                    </svg>Thresholds</a>
            </nav>
            <div class="px-4 py-3 border-t border-white/10">
                <p class="text-xs text-slate-500">Device: <span class="text-sky-400 font-mono">{{.DeviceID}}</span></p>
            </div>
        </aside>

        <main class="relative z-10 ml-56 min-h-screen">
            <header
                class="sticky top-0 z-10 flex items-center justify-between px-8 py-4 border-b border-white/10 bg-slate-950/60 backdrop-blur-md">
                <h1 class="text-xl font-bold text-white">Analysis</h1>
                <div class="flex items-center gap-3">
                    <select id="hours-select"
                        class="bg-slate-800 border border-white/10 text-sm text-slate-200 rounded-lg px-3 py-1.5 focus:outline-none">
                        <option value="1">Last 1 hour</option>
                        <option value="6">Last 6 hours</option>
                        <option value="24" selected>Last 24 hours</option>
                        <option value="72">Last 3 days</option>
                        <option value="168">Last 7 days</option>
                    </select>
                    <button id="refresh-btn"
                        class="text-xs bg-sky-600 hover:bg-sky-500 text-white px-3 py-1.5 rounded-lg transition-colors">Refresh</button>
                </div>
            </header>

            <div class="px-8 py-6 space-y-6">


                <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="stats-row">
                    <div class="stat-card">
                        <p class="stat-label">Avg Temp</p>
                        <p class="stat-val" id="stat-temp-avg">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Max Temp</p>
                        <p class="stat-val text-orange-400" id="stat-temp-max">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Avg Humidity</p>
                        <p class="stat-val" id="stat-hum-avg">—</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">Avg Air Quality</p>
                        <p class="stat-val" id="stat-aq-avg">—</p>
                    </div>
                </div>


                <div class="panel">
                    <h2 class="panel-title">Temperature &amp; Humidity over time</h2>
                    <div class="relative h-[240px]">
                        <canvas id="chart-env"></canvas>
                    </div>
                </div>

                <div class="panel">
                    <h2 class="panel-title">Air Quality (ppm) over time</h2>
                    <div class="relative h-[200px]">
                        <canvas id="chart-aq"></canvas>
                    </div>
                </div>


                <div class="panel">
                    <h2 class="panel-title">Accelerometer (m/s²) over time</h2>
                    <div class="relative h-[200px]">
                        <canvas id="chart-accel"></canvas>
                    </div>
                </div>

                <div class="panel">
                    <h2 class="panel-title">Gyroscope (rad/s) over time</h2>
                    <div class="relative h-[200px]">
                        <canvas id="chart-gyro"></canvas>
                    </div>
                </div>

                <div class="panel">
                    <h2 class="panel-title">Proximity Distance (cm) over time</h2>
                    <div class="relative h-[200px]">
                        <canvas id="chart-dist"></canvas>
                    </div>
                </div>

            </div>
        </main>

        <script src="/assets/js/analysis.js"></script>
        <script>window.SGG_DEVICE_ID = "{{.DeviceID}}";</script>
    </body>

</html>